---
import BaseHead from '../components/BaseHead.astro';
import Link from '../components/ui/Link.astro';
import Text from '../components/ui/Text.astro';

interface Props {
  title: string;
  description?: string;
  fullWidth?: boolean;
  brand?: string;
  links?: Array<{ label: string; href: string }>;
}

const { title, description, fullWidth = false, brand = 'Web Master', links } = Astro.props;
const base = import.meta.env.BASE_URL;
const user = Astro.locals.user;
const navLinks = links ?? [
  { label: 'Home', href: base },
  { label: 'Blog', href: `${base}/blog` },
  { label: 'Templates', href: `${base}/template` },
  { label: 'Reports', href: `${base}/reports` },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <nav>
      <div class="nav-inner">
        <Link href={base} class="brand">{brand}<span class="dot">.</span></Link>
        <div class="nav-links">
          {navLinks.map(link => (
            <Link href={link.href}><Text variant="link">{link.label}</Text></Link>
          ))}
          {user ? (
            <button type="button" id="signout-btn" class="signout"><Text variant="link">Sign out</Text></button>
          ) : (
            <Link href={`${base}/login`}><Text variant="link">Sign in</Text></Link>
          )}
        </div>
      </div>
    </nav>
    <main class:list={[{ contained: !fullWidth }]}>
      <slot />
    </main>
    <footer>
      <div class="footer-inner">
        <Text variant="caption">Built with Astro + SQLite</Text>
      </div>
    </footer>

    <script>
      const base = import.meta.env.BASE_URL;
      function bindSignout() {
        const btn = document.getElementById("signout-btn");
        if (!btn || (btn as HTMLElement).dataset.bound) return;
        (btn as HTMLElement).dataset.bound = "true";
        btn.addEventListener("click", async () => {
          await fetch(`${base}/api/auth/sign-out`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: "{}",
          });
          window.location.href = base;
        });
      }
      bindSignout();
      document.addEventListener("astro:page-load", bindSignout);
    </script>
  </body>
</html>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 1rem 1.5rem;
  }

  nav :global(.brand) {
    font-family: var(--display);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
  }

  .dot {
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  button.signout {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font: inherit;
    color: inherit;
  }

  main.contained {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  footer {
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
    text-align: center;
  }
</style>
