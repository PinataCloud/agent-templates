# Copy to .env locally (never commit .env).
# On Pinata managed deployments, configure these through the platform UI/API —
# .env is not used in production.

# Required by the Authentication module (src/lib/auth.ts).
# Generate a fresh secret per deployment: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL the user hits in the browser, including the /app base.
# Examples:
#   Local:    http://localhost:4321/app
#   Pinata:   https://<agent-id>.agents.pinata.cloud/app
BETTER_AUTH_URL=

# Optional: extra comma-separated origins for the CSRF trusted list.
# Useful when the site is reachable under multiple hosts (custom domain + default).
# BETTER_AUTH_TRUSTED_ORIGINS=https://custom.example.com,https://staging.example.com
